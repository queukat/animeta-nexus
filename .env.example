# Demo generation does not require any credentials.
#
# Real TVDB discovery / reconstruction / contribution workflows may use these
# values. Keep real credentials and browser session files out of Git.

TVDB_API_KEY=
OPENAI_API_KEY=

# Either TVDB_USERNAME or the legacy TVDB_USER name can be used.
TVDB_USERNAME=
TVDB_USER=
TVDB_PASSWORD=
TVDB_PIN=

MODEL_PROVIDER=openai
OPENAI_MODEL=gpt-5-mini

# TVDB language code and human-readable name for generation policy.
TARGET_LANGUAGE=eng
TARGET_LANGUAGE_NAME=English
TVDB_TARGET_LANGUAGE=eng

# Optional local runtime behavior.
TVDB_DELETE_PUSHED_FROM_CHECKPOINT=0
